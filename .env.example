# ─── Augustus Trading ───
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
#
# All thresholds below are OPTIONAL — the defaults are Rafael's production
# values (proven since June 2026). Only uncomment and change what you need.

# ─── Required: Kraken Exchange ──────────────────────────────────────────────
# Generate at: https://www.kraken.com/u/security/api
# Permissions needed: Query Funds, Query Orders, Create/Modify Orders
KRAKEN_API_KEY=your_k...here
KRAKEN_SECRET_KEY=your_k...here

# ─── Required: LLM Provider (pick ONE) ──────────────────────────────────────
# Option A: DeepSeek (recommended, ~$0.87/M output tokens)
# Get key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_d...here
# Option B: OpenRouter (supports many models, ~$1.20/M output)
# Get key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_o...here

# ─── Optional: Data Directory ───────────────────────────────────────────────
# Default: ~/.augustus/
# AUGUSTUS_DATA_DIR=/path/to/data

# ─── Optional: Trading Thresholds ───────────────────────────────────────────
# Defaults are Rafael's production values. Uncomment to customize.
#
# ── Trade Sizing ─────────────────────────────────────────────────────────
# AUGUSTUS_MIN_TRADE_EUR=3.0       # Minimum EUR per trade
# AUGUSTUS_TRADE_PCT=0.15          # % of portfolio per trade (0.15 = 15%)
# AUGUSTUS_MAX_TRADE_EUR=15.0      # Cap per trade in EUR
#
# ── Bear Market Regime (F&G < 30 or BTC < SMA50) ─────────────────────────
# AUGUSTUS_BEAR_CASH=0.35          # Cash target in bear (35%)
# AUGUSTUS_BEAR_RSI=15             # RSI threshold to buy in bear (very oversold)
# AUGUSTUS_BEAR_MAX_POS=0.20       # Max % per asset in bear (20%)
#
# ── Bull Market Regime ───────────────────────────────────────────────────
# AUGUSTUS_BULL_RSI_OVERSOLD=35    # RSI threshold to buy (oversold)
# AUGUSTUS_BULL_RSI_OVERBOUGHT=70  # RSI threshold to sell (overbought)
# AUGUSTUS_MIN_CHANGE_SIGNAL=3.0   # Minimum 24h % change to flag as signal
#
# ── Risk & Sanity Bounds ─────────────────────────────────────────────────
# AUGUSTUS_MAX_CHANGE_4H=20.0      # Max BTC % change in 4h before alert
# AUGUSTUS_MAX_CHANGE_24H=50.0     # Max BTC % change in 24h before reject
# AUGUSTUS_MAX_ALT_CHANGE_24H=80.0 # Max altcoin % change in 24h before reject
# AUGUSTUS_MIN_BTC_EUR=10000       # BTC price floor (sanity check)
# AUGUSTUS_MAX_BTC_EUR=500000      # BTC price ceiling (sanity check)
